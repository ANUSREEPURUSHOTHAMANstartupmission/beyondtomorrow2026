<script is:inline>
// Function to animate the count-up effect for multiple numbers
function animateValues() {
  const countElements = document.querySelectorAll('.count');

  countElements.forEach((countElement) => {
    const start = parseInt(countElement.getAttribute('data-start'));
    const end = parseInt(countElement.getAttribute('data-end'));
    const duration = 6000; // Duration for each count-up animation

    animateValue(countElement, start, end, duration);
  });
}

// Function to animate the count-up effect
function animateValue(element, start, end, duration) {
  const range = end - start;
  const increment = end > start ? 1 : -1;
  const frameDuration = Math.abs(Math.floor(duration / range));
  let current = start;

  const animate = () => {
    current += increment;
    element.textContent = current;

    if ((increment > 0 && current < end) || (increment < 0 && current > end)) {
      setTimeout(animate, frameDuration);
    }
  };

  animate();
}

// Call the animateValues function to start the animation
animateValues();


</script>
<style is:global lang="scss">
	.button{
    position: relative;
    display: block;
    width: 200px;
    height: 45px;
    line-height: 40px;
    color: #fff;
    font-size: 16px;
    font-weight: 500;
