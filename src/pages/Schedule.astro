    &:hover{
      color: #fff;
      position: relative;
      z-index: 1;

      &::before{
        left: 0%;
        right: auto;
        width: 100%;
        z-index: -1;
      }

      &::after{

      }
    }

    &::before{
      position: absolute;
      top: 0px;
      right: 0px;
      height: 100%;
      width: 0px;
      content: '';
      background: #ef5e5e;
      transition: all 0.4s cubic-bezier(0.42, 0, 0.58, 1);
    }

    &::after{
      content: "";
